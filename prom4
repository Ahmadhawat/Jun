def count_gpt_oss_tokens(text: str) -> int:
    encoder = tiktoken.get_encoding("o200k_harmony")
    return len(
        encoder.encode(
            text or "",
            disallowed_special=(),
        )
    )


def build_prompt(
    *,
    intent: str,
    question: str,
    documents: List[Dict[str, Any]],
    system_prom: str,
    instructions_prom: str,
    link_quelle: str,
    chat_history: str = "",
    needs_retrieval: bool = True,
) -> str:
    context = ""

    for i, doc in enumerate(documents, 1):
        source = str(doc.get("source", "")).replace("\\", "/")
        source = source.replace(
            "/root/chat-Hilfe/CARDPT102/Help/content/",
            link_quelle,
        )

        context += f"""
[DOCUMENT {i}]
SOURCE: {source}
CONTENT:
{doc["content"]}
---
"""

    if not context.strip():
        context = "No retrieved documents."

    history_section = chat_history if chat_history.strip() else "No previous conversation."

    return f"""
{system_prom}

---
INTENT:
{intent}

---
NEEDS_RETRIEVAL:
{needs_retrieval}

---
CHAT HISTORY:
{history_section}

---
RETRIEVED DOCUMENTS:
{context}

---
LATEST USER REQUEST:
{question}

---
INSTRUCTIONS:
{instructions_prom}

---
ANSWER:
""".strip()


def query_ollama(
    url: str,
    model: str,
    prompt: str,
    temperature: float = 0.2,
    context_window: int = 8192,
    max_tokens: int = 400,
    timeout: int = 90,
) -> str:
    payload = {
        "model": model,
        "prompt": prompt,
        "stream": False,
        "options": {
            "temperature": temperature,
            "num_ctx": context_window,
            "num_predict": max_tokens,
        },
    }

    resp = requests.post(url, json=payload, timeout=timeout)
    resp.raise_for_status()

    return resp.json()["response"]


class PromptingV2(Prompting):
    name = "PromptingV2"

    def _source_path(self, res: Dict[str, Any]) -> str:
        return str(
            res.get("html_real_path")
            or res.get("txt_path")
            or res.get("chunk_path")
            or res.get("chunk_name")
            or f"chunk_id-{res.get('chunk_id')}"
        )

    def _score(self, res: Dict[str, Any]) -> float:
        score = (
            res.get("scores", {}).get("blended")
            or res.get("scores", {}).get("ce")
            or res.get("scores", {}).get("score")
            or 0.0
        )

        try:
            return float(score)
        except Exception:
            return 0.0

    def _make_doc_from_res(
        self,
        res: Dict[str, Any],
        *,
        use_full_file: bool,
    ) -> Optional[Dict[str, Any]]:
        full_content = str(res.get("chunk_text_content", "") or "").strip()
        chunk_content = str(res.get("chunk_text", "") or "").strip()

        if use_full_file and full_content:
            content = full_content
            mode = "full_file"
        else:
            content = chunk_content or full_content
            mode = "chunk"

        if not content:
            return None

        source_path = self._source_path(res)

        return {
            "chunk_id": res.get("chunk_id"),
            "chunk_name": res.get("chunk_name"),
            "source": source_path,
            "content": content,
            "scores": res.get("scores", {}),
            "_mode": mode,
            "_score": self._score(res),
            "_full_tokens": count_gpt_oss_tokens(full_content) if full_content else 0,
            "_chunk_tokens": count_gpt_oss_tokens(chunk_content) if chunk_content else 0,
        }

    def _select_documents_under_budget(
        self,
        *,
        reranked: List[Dict[str, Any]],
        top_k: int,
        min_docs: int,
        max_prompt_tokens: int,
        reserved_answer_tokens: int,
        intent: str,
        query_text: str,
        sys_prom: str,
        instra_prompt: str,
        link: str,
        chat_history: str,
        needs_retrieval: bool,
        log,
    ) -> List[Dict[str, Any]]:

        def prompt_token_count(docs: List[Dict[str, Any]]) -> int:
            prompt = build_prompt(
                intent=intent,
                question=query_text,
                documents=docs,
                system_prom=sys_prom,
                instructions_prom=instra_prompt,
                link_quelle=link,
                chat_history=chat_history,
                needs_retrieval=needs_retrieval,
            )
            return count_gpt_oss_tokens(prompt)

        def over_budget(docs: List[Dict[str, Any]]) -> bool:
            return prompt_token_count(docs) + reserved_answer_tokens > max_prompt_tokens

        # --------------------------------------------------------------
        # Step 1:
        # Find all unique files from the retrieved chunks.
        # For each file, keep only the best-scoring chunk as fallback.
        # --------------------------------------------------------------
        best_by_source: Dict[str, tuple[float, Dict[str, Any]]] = {}

        for res in reranked[:top_k]:
            source_path = self._source_path(res)
            score = self._score(res)

            current = best_by_source.get(source_path)

            if current is None or score > current[0]:
                best_by_source[source_path] = (score, res)

        best_results = [
            res
            for _score, res in sorted(
                best_by_source.values(),
                key=lambda item: item[0],
                reverse=True,
            )
        ]

        log.info(
            "Found %d unique source files from top %d reranked chunks.",
            len(best_results),
            top_k,
        )

        # --------------------------------------------------------------
        # Step 2:
        # Start with ALL unique files as full files.
        # This is your main goal: use as many full files as possible.
        # --------------------------------------------------------------
        docs: List[Dict[str, Any]] = []

        for res in best_results:
            doc = self._make_doc_from_res(res, use_full_file=True)
            if doc:
                docs.append(doc)

        if not docs:
            return []

        # --------------------------------------------------------------
        # Step 3:
        # If all full files are too large, remove the weakest last files.
        # But do not remove below min_docs.
        # --------------------------------------------------------------
        while len(docs) > min_docs and over_budget(docs):
            removed = docs.pop()

            log.info(
                "Removed weak full file to reduce prompt size: source=%s mode=%s score=%s",
                removed.get("source"),
                removed.get("_mode"),
                removed.get("_score"),
            )

        # --------------------------------------------------------------
        # Step 4:
        # If we are at min_docs and still too large, replace weakest full
        # files with their best chunks instead of deleting them.
        # --------------------------------------------------------------
        while docs and over_budget(docs):
            replaced_any = False

            for idx in range(len(docs) - 1, -1, -1):
                current_doc = docs[idx]

                if current_doc.get("_mode") != "full_file":
                    continue

                source = current_doc["source"]

                original_res = None
                for res in best_results:
                    if self._source_path(res) == source:
                        original_res = res
                        break

                if original_res is None:
                    continue

                chunk_doc = self._make_doc_from_res(
                    original_res,
                    use_full_file=False,
                )

                if not chunk_doc:
                    continue

                docs[idx] = chunk_doc
                replaced_any = True

                log.info(
                    "Replaced full file with chunk: source=%s full_tokens=%d chunk_tokens=%d",
                    source,
                    current_doc.get("_full_tokens", 0),
                    chunk_doc.get("_chunk_tokens", 0),
                )

                break

            if not replaced_any:
                break

        # --------------------------------------------------------------
        # Step 5:
        # If even min_docs chunks are too large, remove weakest chunks.
        # This is only emergency fallback.
        # --------------------------------------------------------------
        while docs and over_budget(docs):
            removed = docs.pop()

            log.warning(
                "Emergency removal because even chunks exceed budget: source=%s mode=%s",
                removed.get("source"),
                removed.get("_mode"),
            )

        final_prompt_tokens = prompt_token_count(docs)

        full_count = sum(1 for doc in docs if doc.get("_mode") == "full_file")
        chunk_count = sum(1 for doc in docs if doc.get("_mode") == "chunk")

        log.info(
            "Final selected docs=%d full_files=%d chunks=%d prompt_tokens=%d reserved_answer_tokens=%d planned_total=%d budget=%d",
            len(docs),
            full_count,
            chunk_count,
            final_prompt_tokens,
            reserved_answer_tokens,
            final_prompt_tokens + reserved_answer_tokens,
            max_prompt_tokens,
        )

        return docs

